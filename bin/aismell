#!/usr/bin/python3
"""Standalone bin entry — works without pip install.

Hardcoded to /usr/bin/python3 (system Python) to avoid PATH-based
collisions with venvs that may not have PyYAML installed.
"""
import sys
from pathlib import Path

# Allow running from repo without install
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from aismell.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
