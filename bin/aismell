#!/usr/bin/env python3
"""Standalone bin entry — works without pip install.

Self-heals against missing PyYAML / PyMuPDF in the active python by
re-execing into a system python that has them. This matters when the
shell is inside a venv that doesn't include the user's pacman/apt
packages (e.g. Hermes Agent's venv shadows /usr/bin/python3).
"""

import os
import shutil
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent

# Modules we'd like to find together. yaml is required; fitz (PyMuPDF)
# is optional but only useful for PDF mode, so we prefer a python that
# has both when given a choice.
REQUIRED = ["yaml"]
PREFERRED = ["yaml", "fitz"]

_MARKER = "_AISMELL_REEXECED"


def _has_modules(py: str, mods: list[str]) -> bool:
    code = "import " + ", ".join(mods)
    try:
        subprocess.check_call(
            [py, "-c", code],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        return True
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False


def _candidate_pythons() -> list[str]:
    found: list[str] = []
    for fixed in (
        "/usr/bin/python3",
        "/usr/local/bin/python3",
        "/opt/homebrew/bin/python3",
    ):
        if Path(fixed).exists() and fixed != sys.executable and fixed not in found:
            found.append(fixed)
    for name in ("python3", "python"):
        candidate = shutil.which(name)
        if candidate and candidate != sys.executable and candidate not in found:
            found.append(candidate)
    return found


def _maybe_reexec():
    """If the current python is missing required modules — or is missing
    optional ones we'd prefer — re-exec into a better python."""
    if os.environ.get(_MARKER) == "1":
        return  # already re-execed once; stop loops

    current_has_required = _has_modules(sys.executable, REQUIRED)
    current_has_preferred = _has_modules(sys.executable, PREFERRED)
    if current_has_preferred:
        return  # we're already golden

    candidates = _candidate_pythons()
    # First pass: a python with everything.
    target = next((py for py in candidates if _has_modules(py, PREFERRED)), None)
    # Second pass (only if we don't have required): one with at least yaml.
    if target is None and not current_has_required:
        target = next((py for py in candidates if _has_modules(py, REQUIRED)), None)
    if target is None:
        return  # nothing better; let the natural error happen below

    env = dict(os.environ)
    env[_MARKER] = "1"
    os.execve(target, [target, str(Path(__file__).resolve()), *sys.argv[1:]], env)


_maybe_reexec()

try:
    import yaml  # noqa: F401
except ImportError:
    msg = [
        "aismell needs PyYAML.",
        "",
        "Install one of these and try again:",
        "  Arch / Manjaro:    sudo pacman -S python-yaml",
        "  Debian / Ubuntu:   sudo apt install python3-yaml",
        "  Fedora:            sudo dnf install python3-pyyaml",
        "  macOS (brew):      brew install pyyaml",
        "  Any system (pip):  pip install --user pyyaml",
        "",
        "If you have it installed but aismell still complains, your shell's",
        "active python doesn't see it. Try:  python3 -m pip install --user pyyaml",
    ]
    print("\n".join(msg), file=sys.stderr)
    sys.exit(1)

sys.path.insert(0, str(REPO_ROOT))
from aismell.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
